# Copy this file to .env and adjust as needed. .env is gitignored.

# --- Postgres ---
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel
POSTGRES_DB=sentinelpress
POSTGRES_PORT=5432

# Full connection string used by Python services (db/, sandbox/, features/, model/)
DATABASE_URL=postgresql://sentinel:sentinel@localhost:5432/sentinelpress

# --- Mock listener (sandbox) ---
MOCK_LISTENER_PORT=8080

# --- Serving ---
SCORER_PORT=8000
ONNX_MODEL_PATH=./model/artifacts/sentinelpress.onnx
